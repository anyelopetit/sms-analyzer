{
  "name": "sms-analyzer",
  "version": "1.0.0",
  "description": "Pure JS utility to analyze SMS message encoding, character count, segment count, and remaining characters.",
  "main": "src/analyzeSmsText.js",
  "scripts": {
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
